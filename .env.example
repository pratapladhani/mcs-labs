# Environment Variables for Playwright Testing

# Microsoft 365 / Copilot Studio Authentication
M365_USERNAME=your.email@company.com
M365_PASSWORD=your_password

# Base URLs
BASE_URL=https://copilotstudio.microsoft.com
M365_COPILOT_URL=https://copilot.microsoft.com
SHAREPOINT_URL=https://yourcompany.sharepoint.com

# Test Configuration
HEADLESS=true
TIMEOUT=30000
RETRIES=2

# Browser Configuration
BROWSER=chromium

# Test Data
TEST_AGENT_NAME=Test-Agent-Playwright
TEST_SHAREPOINT_SITE=Test Site
TEST_KNOWLEDGE_SOURCE=https://docs.microsoft.com/en-us/microsoft-copilot-studio/

# Optional: CI/CD Configuration
CI=false